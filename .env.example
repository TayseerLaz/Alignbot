# ============================================================================
# ALIGNED Business Platform — environment variables
# Copy this file to .env (dev) and to .env.production on the server.
# Never commit .env. Rotate any secret leaked in git history.
# ============================================================================

# --- Core ---------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# --- API server ---------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000
WEB_PUBLIC_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# --- Database -----------------------------------------------------------
# App connects via PgBouncer (port 6432) in prod. Direct 5432 for migrations.
DATABASE_URL="postgresql://aligned:aligned@localhost:5432/aligned?schema=public&pgbouncer=true"
DIRECT_DATABASE_URL="postgresql://aligned:aligned@localhost:5432/aligned?schema=public"

# --- Redis --------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# --- Auth / JWT ---------------------------------------------------------
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET="change-me-access-secret-must-be-at-least-32-characters-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-must-be-at-least-32-characters-long"
JWT_ACCESS_TTL_SECONDS=900
# 604800 = 7 days. Lower bound for refresh-token leak damage window.
JWT_REFRESH_TTL_SECONDS=604800
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# --- Email (SMTP) -------------------------------------------------------
# Dev: leave EMAIL_SMTP_HOST empty to use Mailhog (smtp://localhost:1025)
# Prod: set the AWS SES SMTP block below.
EMAIL_FROM="ALIGNED <noreply@aligned.local>"
EMAIL_DEV_SMTP_HOST=localhost
EMAIL_DEV_SMTP_PORT=1025
#EMAIL_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
#EMAIL_SMTP_PORT=587
#EMAIL_SMTP_USER=
#EMAIL_SMTP_PASS=
#EMAIL_SMTP_SECURE=false

# --- Object storage (Wasabi, S3-compatible) -----------------------------
# Leave keys empty to run dev without uploads (presign endpoint will 503).
WASABI_ENDPOINT="https://s3.eu-central-1.wasabisys.com"
WASABI_REGION="eu-central-1"
WASABI_BUCKET="aligned-dev"
WASABI_ACCESS_KEY_ID=
WASABI_SECRET_ACCESS_KEY=
WASABI_PUBLIC_URL_BASE="https://aligned-dev.s3.eu-central-1.wasabisys.com"
WASABI_SIGNED_URL_TTL_SECONDS=900

# --- WhatsApp (Meta Cloud API) ------------------------------------------
META_WA_PHONE_NUMBER_ID=
META_WA_BUSINESS_ACCOUNT_ID=
META_WA_ACCESS_TOKEN=
META_WA_VERIFY_TOKEN="change-me-webhook-verify-token"
META_WA_APP_SECRET=

# --- Observability ------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Voice gateway (Aseer-time voicebot, shared multi-tenant mode) -------
# Platform secret (NOT org-scoped) shared only with the trusted voicebot infra.
# When set, the voicebot resolves an inbound dialed number to a tenant phone
# line via GET /voice/resolve and posts call lifecycle with this secret +
# X-Phone-Integration-Id. Leave empty to disable gateway mode (per-line
# X-Aligned-Api-Key auth keeps working regardless).
VOICE_GATEWAY_SECRET=

# --- Rate limiting ------------------------------------------------------
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_API_PER_SECOND=100
RATE_LIMIT_READ_API_PER_SECOND=200

# --- Custom CNAMEs / on-demand TLS --------------------------------------
# Hostname customers should point their CNAME at. Caddy issues certs on
# demand once /api/v1/caddy/ask returns 200 for a verified domain.
CUSTOM_CNAME_TARGET="hader.ai"

# --- WAF / edge proxy trust (Sprint 4) ----------------------------------
# Controls which upstream proxies the API trusts when reading
# X-Forwarded-For. See apps/api/src/lib/trust-proxy.ts.
#   true       trust any proxy (default — safe ONLY when the API is
#              behind Caddy on a private network).
#   false      trust none (req.ip = socket peer).
#   cloudflare preset: Cloudflare IPv4 + IPv6 + LAN/loopback.
#   CIDR list  e.g. 10.0.0.0/8,2606:4700::/32
TRUST_PROXY=true
# When 'true', honour CF-Connecting-IP for req.ip. Set ONLY when behind
# Cloudflare and TRUST_PROXY is configured to include their ranges.
TRUST_CF_CONNECTING_IP=false

# --- Groq (chat completions — REQUIRED for bot replies) ---------------
# Llama 3.3 70B on Groq's LPU runs at ~500 tok/sec vs OpenAI's ~50-100
# tok/sec, so bot replies land in 3-8s instead of 22-26s. The API and
# the worker both require this key for chat completions — if it's not
# set, bot reply attempts throw a "GROQ_API_KEY is not configured" error
# instead of silently falling back to OpenAI (which used to mask the
# misconfig). Sign up at https://console.groq.com — free tier is fine
# for low-volume; paid tier removes the 30 req/min limit.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- MyFatoorah (Kuwait payment gateway) -------------------------------
# Used by the bot to mint per-order invoice URLs at checkout. Sandbox
# URL = https://apitest.myfatoorah.com. Production = https://api.myfatoorah.com.
# When MYFATOORAH_API_KEY is unset, the bot's payment-link request
# strips the [PAYMENT_LINK] marker with a soft "we'll send you a link
# shortly" message instead of leaking a fake URL.
MYFATOORAH_API_KEY=
MYFATOORAH_BASE_URL=https://apitest.myfatoorah.com

# --- OpenAI (transcription only) ---------------------------------------
# OpenAI is kept exclusively for voice-note transcription
# (gpt-4o-transcribe is materially better on Arabic dialects than Groq's
# Whisper Large v3 — the platform's customer base is Gulf/Levant Arabic
# so this matters). Chat completions DO NOT use this key.
# Leave empty to disable voice transcription (text-only bot still works).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe

# --- Web (Next.js, prefixed with NEXT_PUBLIC for browser) ---------------
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME="ALIGNED Business Platform"

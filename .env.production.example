# Production env template. Copy to .env.production on the server, edit values,
# `chmod 600 .env.production`, and DO NOT commit it.
NODE_ENV=production
LOG_LEVEL=info

# Domains (Caddy uses these for ACME). Must have DNS A records pointing at this server.
WEB_DOMAIN=hader.ai
API_DOMAIN=api.hader.ai
ACME_EMAIL=ops@hader.ai

# Public URLs (used by the API for links in emails + OAuth-style redirects)
API_PUBLIC_URL=https://api.hader.ai
WEB_PUBLIC_URL=https://hader.ai
NEXT_PUBLIC_API_URL=https://api.hader.ai
CORS_ORIGINS=https://hader.ai

# Postgres + Pgbouncer (compose composes the URLs from these)
POSTGRES_USER=aligned
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=aligned

# JWT secrets — generate with `openssl rand -base64 64`
JWT_ACCESS_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me
# Cookie domain must cover both portal + API hostnames so the refresh cookie
# is sent to api.hader.ai from requests made by hader.ai
COOKIE_DOMAIN=.hader.ai
COOKIE_SECURE=true

# Email — AWS SES SMTP. Domain must be DKIM-verified and account out of sandbox.
# NB: until DKIM is verified for hader.ai in AWS SES, keep sending from a
# domain you've already verified (e.g. the previous alignbot.aligned-tech.com).
# Otherwise SES will reject every send.
EMAIL_FROM="ALIGNED <noreply@alignbot.aligned-tech.com>"
EMAIL_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_SMTP_SECURE=false  # true for port 465, false for 587 (STARTTLS)

# Object storage (Wasabi)
WASABI_ENDPOINT=https://s3.eu-central-1.wasabisys.com
WASABI_REGION=eu-central-1
WASABI_BUCKET=alignbotbucket
WASABI_ACCESS_KEY_ID=
WASABI_SECRET_ACCESS_KEY=
WASABI_PUBLIC_URL_BASE=https://alignbotbucket.s3.eu-central-1.wasabisys.com

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Rate limits
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_API_PER_SECOND=200
RATE_LIMIT_READ_API_PER_SECOND=500

# OpenAI (AI bot builder + bot runtime + crawl analysis). Leave empty to disable.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Cloud TTS (one of two voice-reply providers; selected per-org on /bot).
GOOGLE_TTS_API_KEY=
GOOGLE_TTS_DEFAULT_VOICE_EN=en-US-Neural2-J
GOOGLE_TTS_DEFAULT_VOICE_AR=ar-XA-Wavenet-B

# ElevenLabs TTS (the other voice-reply provider). Same fallback rule:
# missing key or voice id ⇒ provider unavailable, bot routes fall back to text.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# Image registry (GitHub Container Registry)
REGISTRY=ghcr.io/tayseerlaz
TAG=latest

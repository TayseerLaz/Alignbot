# Production env template. Copy to .env.production on the server, edit values,
# `chmod 600 .env.production`, and DO NOT commit it.
NODE_ENV=production
LOG_LEVEL=info

# Domains (Caddy uses these for ACME)
WEB_DOMAIN=app.aligned.com
API_DOMAIN=api.aligned.com
ACME_EMAIL=ops@aligned.com

# Public URLs (used by the API for OAuth-style links + email content)
API_PUBLIC_URL=https://api.aligned.com
WEB_PUBLIC_URL=https://app.aligned.com
NEXT_PUBLIC_API_URL=https://api.aligned.com
CORS_ORIGINS=https://app.aligned.com

# Postgres + Pgbouncer (compose composes the URLs from these)
POSTGRES_USER=aligned
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=aligned

# JWT secrets — generate with `openssl rand -base64 64`
JWT_ACCESS_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me
COOKIE_DOMAIN=aligned.com
COOKIE_SECURE=true

# Email
RESEND_API_KEY=
EMAIL_FROM="ALIGNED <noreply@aligned.com>"

# Object storage (Wasabi)
WASABI_ENDPOINT=https://s3.eu-central-1.wasabisys.com
WASABI_REGION=eu-central-1
WASABI_BUCKET=aligned-prod
WASABI_ACCESS_KEY_ID=
WASABI_SECRET_ACCESS_KEY=
WASABI_PUBLIC_URL_BASE=https://aligned-prod.s3.eu-central-1.wasabisys.com

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Rate limits
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_API_PER_SECOND=200
RATE_LIMIT_READ_API_PER_SECOND=500

# Image registry (Github Container Registry)
REGISTRY=ghcr.io/your-github-org
TAG=latest

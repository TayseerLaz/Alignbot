{
  "name": "@aligned/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "echo 'worker: no build step — running via tsx at runtime'",
    "clean": "rm -rf dist .turbo",
    "dev": "tsx watch --conditions=source --env-file=../../.env --clear-screen=false src/index.ts",
    "start": "tsx --conditions=source src/index.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aligned/db": "workspace:*",
    "@aligned/shared": "workspace:*",
    "@aws-sdk/client-s3": "^3.717.0",
    "@prisma/client": "^6.1.0",
    "@sentry/node": "^8.50.0",
    "bullmq": "^5.34.0",
    "cheerio": "^1.2.0",
    "csv-parse": "^5.6.0",
    "exceljs": "^4.4.0",
    "ioredis": "^5.4.2",
    "nodemailer": "^6.9.16",
    "openai": "^4.77.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.60.0",
    "prom-client": "^15.1.3",
    "undici": "^7.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@aligned/config": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2"
  }
}

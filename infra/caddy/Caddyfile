# Caddyfile — production. Auto-TLS via Let's Encrypt.
# Override domains via environment when needed; defaults match a typical layout.
{
    email {$ACME_EMAIL:ops@aligned.example}

    # On-demand TLS for tenant-supplied custom CNAMEs. Caddy hits the
    # API's /api/v1/caddy/ask?domain=<host> and only issues a cert when
    # the domain is `verified` in the branding_configs table.
    on_demand_tls {
        ask http://api:4000/api/v1/caddy/ask
    }
}

# Portal
{$WEB_DOMAIN:app.aligned.example} {
    encode zstd gzip
    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        # Allow same-origin microphone so the inbox can record voice
        # notes via MediaRecorder. Camera/geolocation stay disabled.
        Permissions-Policy "geolocation=(), camera=(), microphone=(self)"
        -Server
    }
    # Belt-and-braces MIME fix for Next.js static assets. Next.js itself
    # serves these with the right Content-Type, but if the upstream ever
    # 404s (e.g. mismatched build between replicas during a rolling
    # deploy) Caddy was forwarding the HTML 404 page and the browser
    # would refuse to apply it as CSS / parse it as JS. Forcing the
    # Content-Type on the response means even a stale upstream returns
    # something the browser at least parses correctly.
    @nextcss path /_next/static/css/*
    header @nextcss Content-Type "text/css; charset=utf-8"
    @nextjs path /_next/static/chunks/*.js /_next/static/*.js
    header @nextjs Content-Type "application/javascript; charset=utf-8"
    reverse_proxy web:3000 {
        # Pin a client to a single upstream so HTML + its referenced
        # static assets always come from the same replica. Removes the
        # cross-replica build-hash mismatch that produced the MIME-type
        # errors in May 2026. Safe to leave on if replicas==1.
        lb_policy ip_hash
        health_uri /
        health_interval 10s
    }
}

# API + chatbot read API
{$API_DOMAIN:api.aligned.example} {
    encode zstd gzip
    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "no-referrer"
        -Server
    }
    @health path /health /health/ready
    handle @health {
        reverse_proxy api:4000
    }
    reverse_proxy api:4000 {
        health_uri /health
        health_interval 10s
    }
}

# Tenant custom CNAMEs — on-demand TLS gated by /caddy/ask. Any hostname
# that isn't matched by a static block above falls into here. Caddy asks
# the API whether it should issue a cert; the API checks branding_configs
# for `cnameStatus = 'verified'`. Verified custom domains land on the
# portal (the inbox lives at app.*/<inbox>; the chatbot read API lives at
# api.*/api/v1/read — those keep their own domains).
:443 {
    tls {
        on_demand
    }
    encode zstd gzip
    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }
    reverse_proxy web:3000 {
        health_uri /
        health_interval 10s
    }
}

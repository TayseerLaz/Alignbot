{
  "name": "aligned-business-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "db:generate": "pnpm --filter @aligned/db generate",
    "db:migrate": "pnpm --filter @aligned/db migrate",
    "db:migrate:deploy": "pnpm --filter @aligned/db migrate:deploy",
    "db:seed": "pnpm --filter @aligned/db seed",
    "db:reset": "pnpm --filter @aligned/db reset",
    "qa": "pnpm --filter @aligned/e2e preflight && pnpm --filter @aligned/e2e test",
    "qa:gate": "pnpm --filter @aligned/e2e test:tenant-isolation",
    "qa:report": "pnpm --filter @aligned/e2e report",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.9.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}

// ----------------------------------------------------------------------------
// Organization (tenant)
// ----------------------------------------------------------------------------

model Organization {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug      String    @unique @db.Citext
  name      String
  status    OrgStatus @default(active)
  // AI tier the tenant is on. Drives provider routing in lib/openai.ts
  // (`basic` = Groq + gpt-4o-mini fallback; `middle` = OpenAI gpt-4o;
  // `max` = Anthropic Claude Opus). Editable from /aligned-admin.
  aiPlan    AiPlan    @default(basic) @map("ai_plan")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  memberships           Membership[]
  invitations           Invitation[]
  apiKeys               ApiKey[]
  auditLogs             AuditLog[]
  sessions              Session[]
  products              Product[]
  productVariants       ProductVariant[]
  productImages         ProductImage[]
  categories            Category[]
  services              Service[]
  servicePricingTiers   ServicePricingTier[]
  availabilityWindows   AvailabilityWindow[]
  businessInfo          BusinessInfo?
  locations             Location[]
  contactChannels       ContactChannel[]
  faqs                  FAQ[]
  policies              Policy[]
  assets                Asset[]
  // Day 3
  importJobs            ImportJob[]
  importJobRows         ImportJobRow[]
  apiConnectors         ApiConnector[]
  syncRuns              SyncRun[]
  webhookEndpoints      WebhookEndpoint[]
  webhookDeliveries     WebhookDelivery[]
  // Day 4
  catalogRevisions      CatalogRevision[]
  notifications         Notification[]
  // Phase 1.5 / Phase 3
  whatsappChannels      WhatsAppChannel[]
  whatsappThreads       WhatsAppThread[]
  // Phase 2
  botConfig             BotConfig?
  // Phase 3 §5.1.3 + §5.1.4
  subscription          Subscription?
  branding              BrandingConfig?
  dataExports           DataExport[]
  // Phase 4 — Broadcasts
  contacts              Contact[]
  contactTags           ContactTag[]
  segments              Segment[]
  broadcasts            Broadcast[]
  broadcastRecipients   BroadcastRecipient[]
  broadcastEvents       BroadcastEvent[]
  // Phase 5.4 — Sequences (drip)
  sequences             Sequence[]
  sequenceSteps         SequenceStep[]
  sequenceEnrollments   SequenceEnrollment[]
  // Bookings — customer intakes captured by the AI bot
  bookings              Booking[]
  // Carts — customer orders captured by the AI bot or entered manually
  carts                 Cart[]
  // Phase 8 — AI message provenance / audit trail
  systemPromptSnapshots   SystemPromptSnapshot[]
  messageProvenances      MessageProvenance[]
  provenanceSuppressions  ProvenanceSuppression[]
  provenanceFlagDecisions ProvenanceFlagDecision[]

  @@index([status])
  @@map("organizations")
}

// ----------------------------------------------------------------------------
// User — global identity. A user can belong to multiple orgs via Membership.
// ----------------------------------------------------------------------------

model User {
  id                         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                      String     @unique @db.Citext
  emailVerifiedAt            DateTime?  @map("email_verified_at")
  passwordHash               String     @map("password_hash")
  firstName                  String?    @map("first_name")
  lastName                   String?    @map("last_name")
  avatarUrl                  String?    @map("avatar_url")
  status                     UserStatus @default(pending)
  isAlignedAdmin             Boolean    @default(false) @map("is_aligned_admin")
  // Email verification + password reset tokens (hashed). Single-use, short TTL.
  emailVerificationTokenHash String?    @map("email_verification_token_hash")
  emailVerificationExpiresAt DateTime?  @map("email_verification_expires_at")
  passwordResetTokenHash     String?    @map("password_reset_token_hash")
  passwordResetExpiresAt     DateTime?  @map("password_reset_expires_at")
  lastLoginAt                DateTime?  @map("last_login_at")
  failedLoginAttempts        Int        @default(0) @map("failed_login_attempts")
  lockedUntil                DateTime?  @map("locked_until")
  // Phase 5.5 — TOTP 2FA (RFC 6238). Secret base32. Recovery codes hashed
  // individually so a single code leak doesn't expose others.
  totpEnabled                Boolean    @default(false) @map("totp_enabled")
  totpSecret                 String?    @map("totp_secret")
  totpEnrolledAt             DateTime?  @map("totp_enrolled_at")
  recoveryCodesHashed        String[]   @default([]) @map("recovery_codes_hashed")
  // Dashboard widget layout — the ids of widgets the user currently
  // has on their /dashboard, in render order. Persisted server-side
  // so the layout follows the operator across devices / browsers /
  // cleared cookies. NULL = "use the registry's defaults".
  dashboardLayout            Json?      @map("dashboard_layout")
  createdAt                  DateTime   @default(now()) @map("created_at")
  updatedAt                  DateTime   @updatedAt @map("updated_at")

  memberships         Membership[]
  sessions            Session[]
  invitationsSent     Invitation[]     @relation("InvitedBy")
  invitationsAccepted Invitation[]     @relation("AcceptedBy")
  auditLogs           AuditLog[]       @relation("AuditActor")
  // Phase 3
  assignedThreads     WhatsAppThread[] @relation("WhatsAppThreadAssignee")
  // Phase 8 — provenance feedback authorship
  provenanceSuppressionsCreated ProvenanceSuppression[]   @relation("ProvenanceSuppressionAuthor")
  provenanceFlagDecisionsMade   ProvenanceFlagDecision[]  @relation("ProvenanceFlagDecider")

  @@index([status])
  @@map("users")
}

// ----------------------------------------------------------------------------
// Membership — user ↔ org with role
// ----------------------------------------------------------------------------

model Membership {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  role           OrgRole  @default(viewer)
  isActive       Boolean  @default(true) @map("is_active")
  // Phase 3 §5.1.1 — skill-based routing. Free-form lowercase tags
  // (e.g. ["billing", "spanish", "tier-2"]). Threads with a
  // `requiredSkill` are auto-assigned only to members carrying it.
  skills         String[] @default([])
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId, role])
  @@map("memberships")
}

// ----------------------------------------------------------------------------
// Session — refresh-token-backed sessions, one row per device/login
// ----------------------------------------------------------------------------

model Session {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  organizationId   String?   @map("organization_id") @db.Uuid
  refreshTokenHash String    @unique @map("refresh_token_hash")
  // Sprint 1 M-2 — previously-rotated refresh hash. On refresh we move the
  // current hash here, then store the new hash in refreshTokenHash. If a
  // refresh token whose hash matches previousTokenHash is presented, that
  // means someone is replaying a rotated token: revoke the session.
  previousTokenHash String? @unique @map("previous_token_hash")
  // 2026-06-01 — timestamp the previous hash was rotated. The refresh
  // handler uses this for a short replay-grace window: if a presented
  // refresh token matches `previous_token_hash` and the rotation
  // happened within the last few seconds, treat it as a concurrent
  // same-tab refresh (race between SessionProvider bootstrap and any
  // useQuery 401-retry on a hard reload) rather than malicious replay.
  // Outside the window: keep the existing revoke-and-audit behaviour.
  previousTokenRotatedAt DateTime? @map("previous_token_rotated_at")
  // Sprint 1 H-3 — set to true only for ALIGNED-admin impersonation sessions
  // (POST /aligned-admin/orgs/:id/impersonate). Regular logins / switch-org
  // leave this false. The refresh handler uses this flag to decide whether
  // the no-membership admin-role synthesis is legitimate.
  isImpersonation  Boolean   @default(false) @map("is_impersonation")
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address") @db.Inet
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  lastUsedAt       DateTime  @default(now()) @map("last_used_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// ----------------------------------------------------------------------------
// Invitation — invite a teammate to an org with a specific role
// ----------------------------------------------------------------------------

model Invitation {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  email          String           @db.Citext
  role           OrgRole          @default(viewer)
  tokenHash      String           @unique @map("token_hash")
  status         InvitationStatus @default(pending)
  invitedById    String           @map("invited_by_id") @db.Uuid
  acceptedById   String?          @map("accepted_by_id") @db.Uuid
  acceptedAt     DateTime?        @map("accepted_at")
  expiresAt      DateTime         @map("expires_at")
  createdAt      DateTime         @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitedBy", fields: [invitedById], references: [id])
  acceptedBy   User?        @relation("AcceptedBy", fields: [acceptedById], references: [id])

  @@unique([organizationId, email])
  @@index([status, expiresAt])
  @@map("invitations")
}

// ----------------------------------------------------------------------------
// ApiKey — issued per-org for chatbot read API + outbound integrations
// ----------------------------------------------------------------------------

model ApiKey {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  prefix         String    @unique // displayed in UI, e.g. "ak_live_abc123"
  keyHash        String    @map("key_hash")
  scopes         String[]  @default([]) // e.g. ["read:catalog","read:business-info"]
  lastUsedAt     DateTime? @map("last_used_at")
  expiresAt      DateTime? @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")
  createdById    String    @map("created_by_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([revokedAt])
  @@map("api_keys")
}

// ----------------------------------------------------------------------------
// AuditLog — every meaningful state change. Kept tenant-scoped (org_id).
// ----------------------------------------------------------------------------

model AuditLog {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?     @map("organization_id") @db.Uuid
  actorUserId    String?     @map("actor_user_id") @db.Uuid
  action         AuditAction
  entityType     String?     @map("entity_type")
  entityId       String?     @map("entity_id") @db.Uuid
  metadata       Json?
  ipAddress      String?     @map("ip_address") @db.Inet
  userAgent      String?     @map("user_agent")
  createdAt      DateTime    @default(now()) @map("created_at")
  // Sprint 4 — tamper-evident hash chain. Computed by a BEFORE INSERT
  // trigger; the application never sets these directly.
  //
  //   prev_hash = the hash of the immediately-preceding row for this org
  //               (NULL for the org's first row).
  //   hash      = sha256(canonical(row) || prev_hash)
  //
  // Any retroactive edit to a row breaks its hash, AND every later row's
  // prev_hash → cascades through the chain. The verifier in
  // apps/api/scripts/verify-audit-chain.ts walks the chain quarterly.
  prevHash       String?     @map("prev_hash")
  hash           String?

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor        User?         @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([actorUserId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ============================================================================
// CATALOG (Day 2)
// ----------------------------------------------------------------------------
// All tables tenant-scoped via organization_id + Postgres RLS (see rls.sql).
// Money is stored as Int (minor units, e.g. cents) to avoid float drift.
// Search indexes use pg_trgm for fast ILIKE / similarity queries on name/desc.
// ============================================================================

// ----------------------------------------------------------------------------
// Asset — generic file in object storage (Wasabi). Used for product images
// today, will be reused for CSV uploads on Day 3 and avatars later.
// ----------------------------------------------------------------------------

model Asset {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  kind           AssetKind
  storageKey     String    @unique @map("storage_key") // S3 object key
  contentType    String    @map("content_type")
  byteSize       Int       @map("byte_size")
  width          Int?
  height         Int?
  checksumSha256 String?   @map("checksum_sha256")
  uploadedById   String?   @map("uploaded_by_id") @db.Uuid
  metadata       Json?
  createdAt      DateTime  @default(now()) @map("created_at")

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productImages ProductImage[]

  @@index([organizationId, kind, createdAt(sort: Desc)])
  @@map("assets")
}

// ----------------------------------------------------------------------------
// Category — self-referencing tree, tenant-scoped, manual sort order
// ----------------------------------------------------------------------------

model Category {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  parentId       String?  @map("parent_id") @db.Uuid
  name           String
  slug           String   @db.Citext
  description    String?
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       Category?    @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     Category[]   @relation("CategoryTree")
  products     Product[]
  services     Service[]

  @@unique([organizationId, slug])
  @@index([organizationId, parentId, sortOrder])
  @@map("categories")
}

// ----------------------------------------------------------------------------
// Product
// ----------------------------------------------------------------------------

model Product {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String    @map("organization_id") @db.Uuid
  categoryId       String?   @map("category_id") @db.Uuid
  sku              String    @db.Citext
  name             String
  slug             String    @db.Citext
  description      String? // rich text / markdown stored as text
  shortDescription String?   @map("short_description")
  // Price is stored in minor units (e.g. cents). Currency is per-org for v1.
  priceMinor       Int?      @map("price_minor")
  currency         String    @default("USD") @db.Char(3)
  compareAtMinor   Int?      @map("compare_at_minor")
  isAvailable      Boolean   @default(true) @map("is_available")
  stockQuantity    Int?      @map("stock_quantity")
  trackInventory   Boolean   @default(false) @map("track_inventory")
  attributes       Json? // freeform key/value
  searchText       String?   @map("search_text") // denormalised name+desc for trigram search
  // Phase 2 Step 3 — text-embedding-3-small vector for top-K catalog
  // injection in the bot pipeline. Stored as a Float[] of length 1536.
  // Cleared whenever name/shortDescription changes (a trigger or the
  // catalog write paths clear it); a backfill script + on-create hook
  // re-populate. Nullable + soft-fallback: products with no embedding
  // are always included in the candidate set so a missing embedding
  // never silently hides a product from the bot.
  embedding        Float[]   @default([]) @map("embedding")
  embeddingHash    String?   @map("embedding_hash") // sha256 of name+desc when embedded; lets us skip re-embedding
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at") // soft-delete

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  variants     ProductVariant[]
  images       ProductImage[]

  @@unique([organizationId, sku])
  @@unique([organizationId, slug])
  @@index([organizationId, isAvailable, createdAt(sort: Desc)])
  @@index([organizationId, categoryId])
  @@index([organizationId, deletedAt])
  // pg_trgm GIN index added in raw SQL after migration (Prisma can't express it):
  //   CREATE INDEX products_search_trgm_idx ON products USING gin (search_text gin_trgm_ops);
  @@map("products")
}

model ProductVariant {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  productId      String   @map("product_id") @db.Uuid
  sku            String   @db.Citext
  name           String // e.g. "Red / Large"
  options        Json // {"color":"red","size":"large"}
  priceMinor     Int?     @map("price_minor") // overrides parent if set
  stockQuantity  Int?     @map("stock_quantity")
  isAvailable    Boolean  @default(true) @map("is_available")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([organizationId, sku])
  @@index([productId, sortOrder])
  @@map("product_variants")
}

model ProductImage {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  productId      String   @map("product_id") @db.Uuid
  assetId        String   @map("asset_id") @db.Uuid
  altText        String?  @map("alt_text")
  sortOrder      Int      @default(0) @map("sort_order")
  isPrimary      Boolean  @default(false) @map("is_primary")
  createdAt      DateTime @default(now()) @map("created_at")
  // Phase 11.3 — cache of the Meta-side media_id for this image so the
  // WhatsApp send path can skip the per-message upload (~1-2 s round-
  // trip). Meta media_ids are valid for 30 days; the bot send path
  // re-uploads when stale or when the active channel changed.
  metaMediaId          String?   @map("meta_media_id")
  metaMediaIdUploadedAt DateTime? @map("meta_media_id_uploaded_at")
  // Media_ids are scoped to the WhatsApp business account (phone_number_id).
  // Cached id only valid if the active primary channel matches this id.
  metaMediaIdChannelId String?   @map("meta_media_id_channel_id") @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  asset        Asset        @relation(fields: [assetId], references: [id], onDelete: Restrict)

  @@unique([productId, assetId])
  @@index([productId, sortOrder])
  @@map("product_images")
}

// ----------------------------------------------------------------------------
// Service — like Product but with duration + pricing tiers + availability
// ----------------------------------------------------------------------------

model Service {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String    @map("organization_id") @db.Uuid
  categoryId       String?   @map("category_id") @db.Uuid
  slug             String    @db.Citext
  name             String
  description      String?
  shortDescription String?   @map("short_description")
  durationMinutes  Int?      @map("duration_minutes")
  basePriceMinor   Int?      @map("base_price_minor")
  currency         String    @default("USD") @db.Char(3)
  priceUnit        PriceUnit @default(flat) @map("price_unit")
  isAvailable      Boolean   @default(true) @map("is_available")
  bookingRules     Json?     @map("booking_rules") // freeform: { min_notice_hours, max_party_size, ... }
  searchText       String?   @map("search_text")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  pricingTiers ServicePricingTier[]
  availability AvailabilityWindow[]

  @@unique([organizationId, slug])
  @@index([organizationId, isAvailable, createdAt(sort: Desc)])
  @@index([organizationId, categoryId])
  @@index([organizationId, deletedAt])
  @@map("services")
}

model ServicePricingTier {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  serviceId      String    @map("service_id") @db.Uuid
  name           String // e.g. "Standard", "Premium"
  description    String?
  priceMinor     Int       @map("price_minor")
  currency       String    @default("USD") @db.Char(3)
  priceUnit      PriceUnit @default(flat) @map("price_unit")
  sortOrder      Int       @default(0) @map("sort_order")
  features       String[]  @default([])
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, sortOrder])
  @@map("service_pricing_tiers")
}

model AvailabilityWindow {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  serviceId      String    @map("service_id") @db.Uuid
  dayOfWeek      DayOfWeek @map("day_of_week")
  // Times stored as minutes since midnight (0..1440). Simpler than TIME for grids.
  startMinute    Int       @map("start_minute")
  endMinute      Int       @map("end_minute")
  effectiveFrom  DateTime? @map("effective_from") // optional date range
  effectiveUntil DateTime? @map("effective_until")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, dayOfWeek])
  @@map("availability_windows")
}

// ----------------------------------------------------------------------------
// BusinessInfo — single row per org, hours stored as JSON for flexibility.
// Locations / contacts / FAQs / policies are separate tables.
// ----------------------------------------------------------------------------

model BusinessInfo {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String   @unique @map("organization_id") @db.Uuid
  legalName       String?  @map("legal_name")
  tagline         String?
  about           String? // rich text
  websiteUrl      String?  @map("website_url")
  // Operating hours: { "monday": [{open: "09:00", close: "17:00"}], ... }
  operatingHours  Json?    @map("operating_hours")
  // Exceptions / holidays: [{date: "2026-12-25", closed: true, note: "Christmas"}]
  hoursExceptions Json?    @map("hours_exceptions")
  timezone        String   @default("UTC")
  currency        String   @default("USD") @db.Char(3)
  metadata        Json?
  // Booking form definition: { title, intentKeywords[], fields[] }.
  // Operator-defined fields the AI bot asks the customer to fill in
  // when they ask to book a meeting / consultation / appointment.
  bookingForm     Json?    @map("booking_form")
  // Shop / cart form definition: { enabled, title, intentKeywords[],
  // fields[], minOrderMinor, deliveryFeeMinor, freeDeliveryAboveMinor,
  // confirmationMessage }. Mirrors bookingForm in spirit — the AI bot
  // asks the customer for these fields once they've finished building
  // their cart, then emits a [CART: {...}] marker. Independent of
  // bookings: a business can enable both, either, or neither.
  shopForm        Json?    @map("shop_form")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("business_info")
}

model Location {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String // e.g. "Downtown branch"
  addressLine1   String?  @map("address_line1")
  addressLine2   String?  @map("address_line2")
  city           String?
  region         String?
  postalCode     String?  @map("postal_code")
  country        String?  @db.Char(2)
  latitude       Decimal? @db.Decimal(9, 6)
  longitude      Decimal? @db.Decimal(9, 6)
  phone          String?
  email          String?  @db.Citext
  isPrimary      Boolean  @default(false) @map("is_primary")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, sortOrder])
  @@map("locations")
}

model ContactChannel {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  kind           String // "phone" | "email" | "whatsapp" | "instagram" | "x" | ...
  label          String?
  value          String // the actual phone/email/URL
  isPrimary      Boolean  @default(false) @map("is_primary")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, sortOrder])
  @@map("contact_channels")
}

model FAQ {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  question       String
  answer         String // rich text / markdown
  tags           String[]      @default([])
  visibility     FaqVisibility @default(public)
  sortOrder      Int           @default(0) @map("sort_order")
  isPublished    Boolean       @default(true) @map("is_published")
  searchText     String?       @map("search_text")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, isPublished, sortOrder])
  // pg_trgm index added in raw SQL.
  @@map("faqs")
}

model Policy {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  kind           String // "return" | "shipping" | "privacy" | "terms" | custom
  title          String
  content        String // rich text / markdown
  isPublished    Boolean  @default(true) @map("is_published")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, kind])
  @@index([organizationId, sortOrder])
  @@map("policies")
}

// ============================================================================
// IMPORTS / CONNECTORS / WEBHOOKS (Day 3)
// ============================================================================

// ----------------------------------------------------------------------------
// ImportJob — async CSV/XLSX upload, processed by BullMQ worker.
// One ImportJobRow per source row, recording success/failure + parsed payload.
// ----------------------------------------------------------------------------

model ImportJob {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  entityKind     ImportEntityKind @map("entity_kind")
  status         ImportJobStatus  @default(pending)
  // Source file in object storage (Wasabi). Optional for in-memory imports.
  sourceAssetId  String?          @map("source_asset_id") @db.Uuid
  sourceFilename String?          @map("source_filename")
  // Column mapping selected by the user: { "Product Name": "name", "Cost": "priceMinor" }
  columnMapping  Json?            @map("column_mapping")
  // Counts
  totalRows      Int              @default(0) @map("total_rows")
  processedRows  Int              @default(0) @map("processed_rows")
  succeededRows  Int              @default(0) @map("succeeded_rows")
  failedRows     Int              @default(0) @map("failed_rows")
  skippedRows    Int              @default(0) @map("skipped_rows")
  // Lifecycle
  startedAt      DateTime?        @map("started_at")
  finishedAt     DateTime?        @map("finished_at")
  errorMessage   String?          @map("error_message")
  createdById    String?          @map("created_by_id") @db.Uuid
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rows         ImportJobRow[]

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([status, createdAt])
  @@map("import_jobs")
}

model ImportJobRow {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  importJobId    String          @map("import_job_id") @db.Uuid
  rowNumber      Int             @map("row_number") // 1-based, includes header offset
  status         ImportRowStatus
  // Resulting entity (when succeeded) — e.g. product id created/updated.
  resultEntityId String?         @map("result_entity_id") @db.Uuid
  // Parsed source data (raw before validation) for debugging.
  rawData        Json?           @map("raw_data")
  errors         Json? // [{path, message}]
  createdAt      DateTime        @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  importJob    ImportJob    @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId, status])
  @@index([importJobId, rowNumber])
  @@map("import_job_rows")
}

// ----------------------------------------------------------------------------
// ApiConnector — outbound pull from a client's external system (REST).
// SyncRun records each execution.
// ----------------------------------------------------------------------------

model ApiConnector {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId      String            @map("organization_id") @db.Uuid
  name                String
  entityKind          ImportEntityKind  @map("entity_kind")
  endpointUrl         String?           @map("endpoint_url")
  authKind            ConnectorAuthKind @default(none) @map("auth_kind")
  // Encrypted-at-rest credentials would normally live in a vault; for v1 we store
  // them in JSONB and recommend pg_crypto in prod. The structure depends on authKind:
  //   bearer:  { token: "..." }
  //   api_key: { headerName: "X-…", value: "..." }
  //   basic:   { username: "...", password: "..." }
  //   hmac:    { secret: "...", header: "X-Sig" }
  authConfig          Json?             @map("auth_config")
  // Cron schedule. NULL = webhook-only (inbound).
  scheduleCron        String?           @map("schedule_cron")
  // Mapping spec (same shape as ImportJob.columnMapping).
  columnMapping       Json?             @map("column_mapping")
  // Webhook secret used to verify inbound calls (HMAC over body).
  webhookSecret       String?           @map("webhook_secret")
  status              ConnectorStatus   @default(active)
  lastRunAt           DateTime?         @map("last_run_at")
  lastSuccessAt       DateTime?         @map("last_success_at")
  consecutiveFailures Int               @default(0) @map("consecutive_failures")
  createdById         String?           @map("created_by_id") @db.Uuid
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  syncRuns     SyncRun[]

  @@index([organizationId, status])
  @@map("api_connectors")
}

model SyncRun {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String        @map("organization_id") @db.Uuid
  connectorId     String        @map("connector_id") @db.Uuid
  trigger         SyncTrigger
  status          SyncRunStatus @default(pending)
  startedAt       DateTime?     @map("started_at")
  finishedAt      DateTime?     @map("finished_at")
  recordsFetched  Int           @default(0) @map("records_fetched")
  recordsUpserted Int           @default(0) @map("records_upserted")
  recordsFailed   Int           @default(0) @map("records_failed")
  errorMessage    String?       @map("error_message")
  metadata        Json?
  createdAt       DateTime      @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connector    ApiConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@index([connectorId, createdAt(sort: Desc)])
  @@index([organizationId, status, createdAt(sort: Desc)])
  @@map("sync_runs")
}

// ----------------------------------------------------------------------------
// Outbound webhooks — notify customer systems / chatbot when catalog changes.
// HMAC-SHA256 signature in `X-Aligned-Signature` header.
// ----------------------------------------------------------------------------

model WebhookEndpoint {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId      String             @map("organization_id") @db.Uuid
  url                 String
  description         String?
  // Subscribed event kinds. Empty/null = subscribe to all.
  eventKinds          WebhookEventKind[] @default([]) @map("event_kinds")
  signingSecret       String             @map("signing_secret") // displayed once on create
  isActive            Boolean            @default(true) @map("is_active")
  // For automatic disabling after too many consecutive failures.
  consecutiveFailures Int                @default(0) @map("consecutive_failures")
  lastDeliveryAt      DateTime?          @map("last_delivery_at")
  createdById         String?            @map("created_by_id") @db.Uuid
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries   WebhookDelivery[]

  @@index([organizationId, isActive])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String                @map("organization_id") @db.Uuid
  endpointId      String                @map("endpoint_id") @db.Uuid
  eventKind       WebhookEventKind      @map("event_kind")
  payload         Json
  status          WebhookDeliveryStatus @default(pending)
  attempts        Int                   @default(0)
  // Last response (truncated body kept for diagnostics).
  responseStatus  Int?                  @map("response_status")
  responseBody    String?               @map("response_body")
  responseHeaders Json?                 @map("response_headers")
  scheduledFor    DateTime              @default(now()) @map("scheduled_for")
  attemptedAt     DateTime?             @map("attempted_at")
  deliveredAt     DateTime?             @map("delivered_at")
  errorMessage    String?               @map("error_message")
  createdAt       DateTime              @default(now()) @map("created_at")

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  endpoint     WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, createdAt(sort: Desc)])
  @@index([status, scheduledFor])
  @@map("webhook_deliveries")
}

// ============================================================================
// VERSIONING + NOTIFICATIONS (Day 4)
// ============================================================================

// ----------------------------------------------------------------------------
// CatalogRevision — append-only history of catalog mutations.
// One row per create/update/delete on a tracked entity. The `snapshot` is the
// post-mutation state for create/update, and the pre-deletion state for delete.
// Restores read the snapshot and apply it back to the live row.
// ----------------------------------------------------------------------------

model CatalogRevision {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  entityType     RevisionEntityType @map("entity_type")
  entityId       String             @map("entity_id") @db.Uuid
  action         RevisionAction
  snapshot       Json
  // Optional human-readable summary (e.g. "Updated price from $19 to $24")
  summary        String?
  actorUserId    String?            @map("actor_user_id") @db.Uuid
  // The "version number" for this entity, monotonically increasing per (entityType, entityId).
  // Computed by the application (count + 1) inside the same transaction so it stays consistent.
  versionNumber  Int                @map("version_number")
  createdAt      DateTime           @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([entityType, entityId, versionNumber])
  @@index([organizationId, entityType, entityId, createdAt(sort: Desc)])
  @@index([organizationId, createdAt(sort: Desc)])
  @@map("catalog_revisions")
}

// ----------------------------------------------------------------------------
// Notification — in-app notifications shown in the bell icon dropdown.
// Generated by the worker on import/sync events and by API key first-use.
// ----------------------------------------------------------------------------

model Notification {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  // If set, only this user sees the notification. NULL = visible to all org members.
  targetUserId   String?              @map("target_user_id") @db.Uuid
  kind           NotificationKind
  severity       NotificationSeverity @default(info)
  title          String
  body           String?
  // Optional deep link (e.g. /imports/<id>)
  link           String?
  // Optional reference back to the entity that triggered this.
  entityType     String?              @map("entity_type")
  entityId       String?              @map("entity_id") @db.Uuid
  metadata       Json?
  readAt         DateTime?            @map("read_at")
  // Per-user read state when targetUserId is NULL: stored as user IDs that have
  // read the notification. Cheap for small teams; revisit if orgs grow.
  readByUserIds  String[]             @default([]) @map("read_by_user_ids") @db.Uuid
  createdAt      DateTime             @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([organizationId, targetUserId, createdAt(sort: Desc)])
  @@map("notifications")
}

// ============================================================================
// PHASE 1.5
// ----------------------------------------------------------------------------
// WhatsAppChannel — per-org WhatsApp Cloud API config. Stores Meta credentials
// (WABA ID, phone number ID, app secret, system-user access token), the
// platform-generated webhook verify token, and the bot's greeting/profile
// fields. One row per organisation.
//
// Security note: accessToken + appSecret are stored plain in this column.
// Same model as ApiConnector.authConfig — RLS-isolated, never returned over
// the API except masked. Encryption-at-rest is the disk's job; encryption
// at the application layer is a TODO before broad rollout.
// ----------------------------------------------------------------------------

model WhatsAppChannel {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId     String    @map("organization_id") @db.Uuid
  // Multiple numbers per org are supported (Phase 3 §5.1.2). Exactly ONE
  // row per org is marked primary; the partial unique index in the
  // accompanying migration enforces this.
  isPrimary          Boolean   @default(true) @map("is_primary")
  // Human-readable label shown in the UI when an org has > 1 number.
  label              String?
  // ---- Meta-side identifiers (visible-ish, copied from Meta dashboard) ----
  wabaId             String?   @map("waba_id")
  phoneNumberId      String?   @map("phone_number_id")
  displayPhoneNumber String?   @map("display_phone_number") // E.164, for UI
  appId              String?   @map("app_id")
  // ---- Secrets — never returned plain in API responses ---------------------
  accessToken        String?   @map("access_token")
  appSecret          String?   @map("app_secret")
  // ---- Platform-generated, given to client to paste into Meta -------------
  webhookVerifyToken String    @map("webhook_verify_token")
  // ---- Bot profile + behaviour --------------------------------------------
  greetingMessage    String?   @map("greeting_message")
  businessName       String?   @map("business_name")
  businessAbout      String?   @map("business_about")
  businessAddress    String?   @map("business_address")
  businessEmail      String?   @map("business_email")
  // ---- Operational state ---------------------------------------------------
  isActive           Boolean   @default(false) @map("is_active")
  lastVerifiedAt     DateTime? @map("last_verified_at")
  lastVerifyStatus   String?   @map("last_verify_status") // 'success' | 'token_invalid' | 'phone_not_found' | network error string
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("whatsapp_channels")
}

// WhatsAppMessage — every inbound message Meta delivers to our webhook is
// persisted here for support / debugging. Outbound replies (sent via
// /whatsapp/test-send for now) are also persisted with direction='outbound'.
// Phase 1.5 does not yet auto-respond — this is just an audit table.

model WhatsAppMessage {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  // Phase 3 §5.1.1 — every message belongs to exactly one thread (per
  // customer phone). Set by the inbound webhook + outbound send paths.
  threadId       String?   @map("thread_id") @db.Uuid
  direction      String // 'inbound' | 'outbound'
  // Meta's wamid for inbound; for outbound, the messages[0].id from the response.
  metaMessageId  String?   @map("meta_message_id")
  fromNumber     String?   @map("from_number")
  toNumber       String?   @map("to_number")
  messageType    String?   @map("message_type") // 'text' | 'template' | 'image' | ...
  body           String?
  // Phase 3 §5.1.1 — Meta delivery / read state for outbound messages.
  // Updated by the message_status webhook. Values mirror Meta:
  // 'sent' | 'delivered' | 'read' | 'failed' | null.
  metaStatus     String?   @map("meta_status")
  metaStatusAt   DateTime? @map("meta_status_at")
  // Phase 3: when message has media, the asset row holding the file we
  // received from Meta or sent through Meta. NULL for text messages.
  mediaAssetId   String?   @map("media_asset_id") @db.Uuid
  // Full payload from Meta (or what we sent) — for debugging.
  rawPayload     Json?     @map("raw_payload")
  receivedAt     DateTime  @default(now()) @map("received_at")

  thread     WhatsAppThread?    @relation(fields: [threadId], references: [id], onDelete: SetNull)
  provenance MessageProvenance?

  @@index([organizationId, receivedAt(sort: Desc)])
  @@index([threadId, receivedAt(sort: Asc)])
  @@map("whatsapp_messages")
}

// ----------------------------------------------------------------------------
// Phase 3 §5.1.1 — Conversation inbox.
// One WhatsAppThread per (org, customer phone). Messages are linked via
// `whatsapp_messages.thread_id`. Status / assignment / tags / internal
// notes hang off the thread.
// ----------------------------------------------------------------------------

enum WhatsAppThreadStatus {
  open
  pending
  resolved
  escalated
}

model WhatsAppThread {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId       String               @map("organization_id") @db.Uuid
  customerPhone        String               @map("customer_phone")
  // Operator-set nickname / business name. Free-form. Mirrored from
  // Contact.displayName on rename so /inbox and /contacts stay in sync.
  customerName         String?              @map("customer_name")
  // Mirror of Meta's WhatsApp profile name from inbound contacts[].
  // profile.name. Read-only; refreshed on every inbound. Lets the
  // inbox row show both the operator's rename AND what the customer
  // actually goes by on WhatsApp.
  customerWhatsappName String?              @map("customer_whatsapp_name")
  status               WhatsAppThreadStatus @default(open)
  assignedToUserId     String?              @map("assigned_to_user_id") @db.Uuid
  // Optional skill that auto-assign should match a member by.
  requiredSkill        String?              @map("required_skill")
  // Phase 6 — per-thread bot reply-mode override. NULL = inherit
  // BotConfig.replyMode. Lets operators flip a single conversation
  // to text or voice without changing the org-wide default.
  botReplyMode         String?              @map("bot_reply_mode")
  lastMessageAt        DateTime             @default(now()) @map("last_message_at")
  lastMessagePreview   String?              @map("last_message_preview")
  inboundCount         Int                  @default(0) @map("inbound_count")
  outboundCount        Int                  @default(0) @map("outbound_count")
  // Search blob — concatenation of recent messages, kept up-to-date by the
  // upsert path. pg_trgm GIN index added in the migration.
  searchText           String               @default("") @map("search_text")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedTo   User?               @relation("WhatsAppThreadAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  messages     WhatsAppMessage[]
  tags         WhatsAppThreadTag[]
  notes        WhatsAppNote[]
  bookings     Booking[]
  carts        Cart[]

  @@unique([organizationId, customerPhone])
  @@index([organizationId, lastMessageAt(sort: Desc)])
  @@index([organizationId, status, lastMessageAt(sort: Desc)])
  @@map("whatsapp_threads")
}

// ----------------------------------------------------------------------------
// Booking — one row per completed intake. The bot collects every field in
// BusinessInfo.bookingForm.fields[] from the customer in WhatsApp, then we
// snapshot the form (with values) here so the row stays correct even if the
// form is edited later.
// ----------------------------------------------------------------------------
model Booking {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId     String    @map("organization_id") @db.Uuid
  threadId           String?   @map("thread_id") @db.Uuid
  customerPhone      String    @map("customer_phone")
  customerName       String?   @map("customer_name")
  // Frozen snapshot of the form at booking time:
  // [{ key, label, type, required, value }]
  fields             Json      @default("[]")
  status             String    @default("new")
  notes              String?
  // Resolved appointment timestamp. The bookings page parses the
  // (possibly natural-language) date+time fields on the row and PATCHes
  // this back; the reminder tick reads it directly to decide when to fire.
  // Nullable because not every booking has a parseable appointment.
  appointmentAt      DateTime? @map("appointment_at")
  // Operator-picked, pre-approved WhatsApp template to send as the
  // 2-hour reminder. NULL = reminder disabled for this booking.
  reminderTemplateId String?   @map("reminder_template_id") @db.Uuid
  // Stamped by the reminder tick after a successful Meta send so we
  // never send twice for the same booking.
  reminderSentAt     DateTime? @map("reminder_sent_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  thread           WhatsAppThread?   @relation(fields: [threadId], references: [id], onDelete: SetNull)
  reminderTemplate WhatsAppTemplate? @relation(fields: [reminderTemplateId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, createdAt(sort: Desc)])
  @@index([organizationId, customerPhone])
  // Tick query: confirmed bookings with a reminder configured whose
  // appointment falls inside the firing window. Partial index is the
  // cheapest way to make the tick scan tiny.
  @@index([status, reminderSentAt, appointmentAt], map: "bookings_reminder_due_idx")
  @@map("bookings")
}

// ----------------------------------------------------------------------------
// Cart / Shop — sibling to Booking. One row per customer order. The AI bot
// collects items + the BusinessInfo.shopForm.fields[] answers from the
// customer in WhatsApp, then emits a [CART: {...}] marker that the inbound
// receiver translates into one Cart row + N CartItem rows.
//
// Status flow (Phase 1, simple): new → confirmed → completed (+ cancelled).
// All non-`new` transitions are operator-driven from the dashboard.
// ----------------------------------------------------------------------------
model Cart {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  threadId       String?  @map("thread_id") @db.Uuid
  customerPhone  String   @map("customer_phone")
  customerName   String?  @map("customer_name")
  // Frozen snapshot of the shopForm's `fields[]` answers — same shape
  // as Booking.fields. [{ key, label, type, required, value }].
  fields         Json     @default("[]")
  // Cart-level money. All in `currency`. subtotalMinor = sum of
  // CartItem.lineTotalMinor; totalMinor = subtotal + delivery.
  subtotalMinor  Int      @default(0) @map("subtotal_minor")
  deliveryMinor  Int      @default(0) @map("delivery_minor")
  totalMinor     Int      @default(0) @map("total_minor")
  currency       String   @default("USD") @db.Char(3)
  // 'new' | 'confirmed' | 'completed' | 'cancelled'
  status         String   @default("new")
  notes          String?
  // Denormalized count for fast list rendering — kept in sync by the
  // route layer (no Prisma middleware to do it implicitly).
  itemsCount     Int      @default(0) @map("items_count")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  thread       WhatsAppThread? @relation(fields: [threadId], references: [id], onDelete: SetNull)
  items        CartItem[]

  @@index([organizationId, status, createdAt(sort: Desc)])
  @@index([organizationId, customerPhone])
  @@map("carts")
}

model CartItem {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  cartId         String   @map("cart_id") @db.Uuid
  // FK snapshots — products / services may change or get soft-deleted
  // after the cart is placed. We keep `name`, `sku`, `variantLabel` as
  // frozen text so historical orders render correctly.
  productId      String?  @map("product_id") @db.Uuid
  serviceId      String?  @map("service_id") @db.Uuid
  variantId      String?  @map("variant_id") @db.Uuid
  sku            String?
  name           String
  variantLabel   String?  @map("variant_label")
  quantity       Int      @default(1)
  unitPriceMinor Int      @map("unit_price_minor")
  lineTotalMinor Int      @map("line_total_minor")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@index([cartId])
  @@map("cart_items")
}

model WhatsAppThreadTag {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  threadId       String   @map("thread_id") @db.Uuid
  tag            String
  createdAt      DateTime @default(now()) @map("created_at")

  thread WhatsAppThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, tag])
  @@index([organizationId, tag])
  @@map("whatsapp_thread_tags")
}

// Internal notes — visible to agents only, never sent to Meta.
model WhatsAppNote {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  threadId       String   @map("thread_id") @db.Uuid
  authorUserId   String?  @map("author_user_id") @db.Uuid
  body           String
  createdAt      DateTime @default(now()) @map("created_at")

  thread WhatsAppThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt(sort: Asc)])
  @@map("whatsapp_notes")
}

// Per-org canned response template for fast agent replies.
model CannedResponse {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  shortcut       String // e.g. "/hours" — typed in the reply box
  body           String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, shortcut])
  @@index([organizationId])
  @@map("canned_responses")
}

// Phase 3 §5.1.2 — submitted WhatsApp message templates with their Meta
// approval status. Required for sending outside the 24h customer window.
model WhatsAppTemplate {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  name            String // Meta-side template name
  language        String   @default("en_US")
  category        String // 'MARKETING' | 'UTILITY' | 'AUTHENTICATION'
  bodyText        String   @map("body_text")
  // Full Meta-shaped components array (header / body / footer /
  // buttons + per-placeholder examples). Source of truth when
  // submitting to Meta; bodyText is kept for search + the
  // chatbot-read API.
  components      Json?
  status          String   @default("draft") // 'draft' | 'pending' | 'approved' | 'rejected'
  rejectionReason String?  @map("rejection_reason")
  metaTemplateId  String?  @map("meta_template_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Bookings that picked this template as their 2-hour reminder.
  reminderBookings Booking[]

  @@unique([organizationId, name, language])
  @@index([organizationId])
  @@map("whatsapp_templates")
}

// ============================================================================
// PHASE 2 — AI Bot Builder
// ----------------------------------------------------------------------------
// BotConfig holds the per-org bot personality, conversation flow, response
// templates, languages, and escalation rules. KnowledgeBase rows are the
// LLM-extracted facts (FAQs, products, policies) the bot answers from.
// CrawlJob + CrawlPage track the website-analysis pipeline.
// BotSimulationSession persists test transcripts so accuracy scores can be
// re-shown without re-running the LLM.
// ============================================================================

enum CrawlJobStatus {
  pending
  running
  succeeded
  partial
  failed
  cancelled
}

model BotConfig {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId          String    @unique @map("organization_id") @db.Uuid
  // Personality preset name + free-form override.
  personality             String? // 'formal' | 'casual' | 'friendly' | 'clinical' | custom
  customPersonality       String?   @map("custom_personality")
  // Detected by the LLM during analysis. Used to seed the personality picker.
  detectedTone            String?   @map("detected_tone")
  // The greeting text the bot opens with.
  greeting                String?
  // If true, the bot's FIRST reply in a thread addresses the customer
  // by their WhatsApp profile name (Meta's contacts[].profile.name,
  // stored on WhatsAppThread.customerWhatsappName). Subsequent replies
  // are unaffected. Defaults off so existing tenants don't see new
  // behaviour without opting in.
  greetByName             Boolean   @default(false) @map("greet_by_name")
  // Comma-separated language codes the bot replies in. Default 'en'.
  languages               String    @default("en")
  // Escalation rules — what triggers a handoff to a human, business hours, etc.
  escalationRules         Json?     @map("escalation_rules")
  // Conversation flow — for now a JSON object keyed by intent (greeting,
  // product_inquiry, booking, support, escalation) with prompt overrides.
  // Drag-and-drop editor shipping later replaces this with a node graph.
  conversationFlow        Json?     @map("conversation_flow")
  // Pre-generated response templates: { intent_key: "template text" }
  responseTemplates       Json?     @map("response_templates")
  // True once the client clicks "Deploy". Inbound webhook's bot-runtime
  // hook only fires when this is set + WhatsAppChannel.isActive is true.
  deployedAt              DateTime? @map("deployed_at")
  // Simple version counter, bumped on every PUT. Surfaced in the UI so
  // the operator can see when something changed.
  version                 Int       @default(1)
  // Phase 6 — TTS reply mode.
  //   text            : current behaviour. Plain WhatsApp text reply.
  //   voice           : every reply spoken with Google Cloud TTS.
  //   match_customer  : voice when the customer's last inbound was a
  //                     voice note; text otherwise.
  replyMode               String    @default("text") @map("reply_mode")
  // TTS provider — `google` (default) or `elevenlabs`. Each provider
  // has independent credentials in env; falling back to text if the
  // chosen provider isn't configured.
  ttsProvider             String    @default("google") @map("tts_provider")
  // Voice identifier — for Google this is the voice NAME
  // (en-US-Neural2-J, ar-XA-Wavenet-B). For ElevenLabs it's the 20-char
  // VOICE ID. Falls back to provider-specific env defaults when null.
  ttsVoiceName            String?   @map("tts_voice_name")
  // Optional Wasabi storage key for an image that's attached to the
  // bot's greeting reply (e.g. a brand banner or "welcome" graphic).
  // When set, the bot sends this image alongside any reply that opens
  // with a greeting word (hi/hello/مرحبا/etc.). Dedup keeps it from
  // re-attaching within a 24h window per thread.
  greetingImageStorageKey String?   @map("greeting_image_storage_key")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("bot_configs")
}

// One CrawlJob per analyze request. It walks pages, extracts text, and
// fans out LLM analysis. Done once per onboarding; clients re-run when
// their site changes.
model CrawlJob {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  rootUrl        String         @map("root_url")
  status         CrawlJobStatus @default(pending)
  // Limits: max pages crawled (cap on cost) + how deep to follow links.
  maxPages       Int            @default(30) @map("max_pages")
  maxDepth       Int            @default(2) @map("max_depth")
  pagesCrawled   Int            @default(0) @map("pages_crawled")
  pagesFailed    Int            @default(0) @map("pages_failed")
  errorMessage   String?        @map("error_message")
  startedAt      DateTime?      @map("started_at")
  finishedAt     DateTime?      @map("finished_at")
  createdAt      DateTime       @default(now()) @map("created_at")

  pages CrawlPage[]

  @@index([organizationId, createdAt(sort: Desc)])
  @@map("crawl_jobs")
}

model CrawlPage {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  crawlJobId     String   @map("crawl_job_id") @db.Uuid
  url            String
  title          String?
  // Cleaned text — boilerplate stripped. Capped at 100 KB per page.
  bodyText       String?  @map("body_text")
  fetchStatus    Int?     @map("fetch_status")
  errorMessage   String?  @map("error_message")
  createdAt      DateTime @default(now()) @map("created_at")

  crawlJob CrawlJob @relation(fields: [crawlJobId], references: [id], onDelete: Cascade)

  @@index([crawlJobId])
  @@map("crawl_pages")
}

// Knowledge-base entries the bot answers from. Sourced by LLM extraction
// from the crawl + Phase 1 catalog data. Each row is one FAQ-shaped fact.
model KnowledgeBaseEntry {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  // 'faq' | 'product' | 'policy' | 'service' | 'business_info' | 'custom'
  kind           String
  question       String
  answer         String
  // Where it came from, for trust & traceability.
  sourceUrl      String?  @map("source_url")
  sourceType     String   @default("ai") @map("source_type") // 'ai' | 'manual'
  // The client can edit AI-generated entries; we mark approved=true once
  // they've reviewed the row.
  approved       Boolean  @default(false)
  // pg_trgm-indexed search blob = question || ' ' || answer.
  searchText     String   @default("") @map("search_text")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([organizationId, kind])
  @@index([organizationId, approved])
  @@map("knowledge_base_entries")
}

// Test scenarios: pre-defined transcripts the operator runs to score the
// bot before deploy. We persist the LAST run so the UI can show last
// scores without re-spending LLM tokens on every page load.
// Bot test scenarios — DB-backed (replaces the formerly-hardcoded
// `SCENARIOS` array in bot.routes.ts). Each org owns its own set, generated
// from its current knowledge base + catalog by an LLM and editable / deletable
// by the operator. Re-generating from a refreshed KB produces a new batch.
model BotTestScenario {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  // Stable slug per scenario (e.g. "menu_question_juices", "delivery_zones",
  // "halal_query"). Used to dedupe across regenerations.
  key            String
  // The user-side prompt the bot should be tested against.
  prompt         String
  // Plain-English description of what a passing response looks like —
  // fed to the LLM-as-judge alongside the bot's reply.
  expectation    String
  // 'ai_generated' = derived from current KB; 'manual' = operator-authored
  // and preserved across regenerations.
  source         String   @default("ai_generated")
  // Soft sort key so operators can drag-reorder later if they like.
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, key])
  @@index([organizationId, sortOrder])
  @@map("bot_test_scenarios")
}

// Bot conversation-flow candidates — the AI builder recommends 3-5 flow
// templates tailored to the business (e.g. "Quick Order Bot", "Hospitality
// Concierge", "Support First"). Exactly one is marked active and its `flow`
// JSON gets mirrored into BotConfig.conversationFlow so the runtime keeps
// reading a single source of truth.
model BotConversationFlowOption {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  name            String
  description     String
  // Flow JSON in the same { nodes: [{ intent, label, response }] } shape
  // bot-engine already consumes.
  flow            Json
  // The LLM's pick for this business — exactly one option per org carries
  // `isRecommended = true`; the others are alternatives.
  isRecommended   Boolean  @default(false) @map("is_recommended")
  // Why the LLM thinks this fits — short, shown under the card title.
  recommendReason String?  @map("recommend_reason")
  isSelected      Boolean  @default(false) @map("is_selected")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([organizationId, isSelected])
  @@map("bot_conversation_flow_options")
}

model BotTestRun {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String    @map("organization_id") @db.Uuid
  scenarioKey      String    @map("scenario_key") // e.g. 'product_question'
  scenarioPrompt   String    @map("scenario_prompt")
  botResponse      String    @map("bot_response")
  // 0..100 — LLM-as-judge score against expected behaviour.
  score            Int?
  judgeNotes       String?   @map("judge_notes")
  // Operator override — when the human disagrees with the judge. The
  // original LLM score on `score` is kept for audit; UI prefers
  // overrideScore when present.
  overrideScore    Int?      @map("override_score")
  overrideNotes    String?   @map("override_notes")
  overrideByUserId String?   @map("override_by_user_id") @db.Uuid
  overrideAt       DateTime? @map("override_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([organizationId, scenarioKey, createdAt(sort: Desc)])
  @@map("bot_test_runs")
}

// Live preview — every simulator turn is persisted so we can replay it.
// Threaded by sessionId (a client-side uuid).
model BotSimulationTurn {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  sessionId      String   @map("session_id")
  role           String // 'user' | 'assistant'
  body           String
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([organizationId, sessionId, createdAt])
  @@map("bot_simulation_turns")
}

// ============================================================================
// PHASE 3 §5.1.3 — Subscription & billing.
// ----------------------------------------------------------------------------
// Plan seeded once per environment (Starter/Growth/Enterprise + Free).
// Subscription is per-org, mirrors Stripe state.
// UsageEvent is append-only; UsageMonthly is a roll-up so cap checks are O(1).
// ============================================================================

enum SubscriptionStatus {
  trialing
  active
  past_due
  cancelled
  free // post-trial without payment — read-only soft cap
  paused
}

model Plan {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // Stable code used in env-driven seeds + Stripe Price metadata.
  code                 String   @unique
  name                 String
  isActive             Boolean  @default(true) @map("is_active")
  // Caps — null = unlimited.
  productCap           Int?     @map("product_cap")
  serviceCap           Int?     @map("service_cap")
  memberCap            Int?     @map("member_cap")
  monthlyMessageCap    Int?     @map("monthly_message_cap")
  monthlyImportCap     Int?     @map("monthly_import_cap")
  // Dedicated cap on broadcast campaigns started per calendar month
  // (a "broadcast" = one campaign, regardless of recipient count).
  // Recipient sends still count against monthlyMessageCap; this is a
  // separate ceiling so heavy senders can't burn the plan with one
  // gigantic fanout.
  monthlyBroadcastCap  Int?     @map("monthly_broadcast_cap")
  apiKeyCap            Int?     @map("api_key_cap")
  webhookCap           Int?     @map("webhook_cap")
  // Pricing display + Stripe wiring.
  priceMonthlyMinor    Int?     @map("price_monthly_minor")
  priceYearlyMinor     Int?     @map("price_yearly_minor")
  currency             String   @default("USD")
  stripePriceMonthlyId String?  @map("stripe_price_monthly_id")
  stripePriceYearlyId  String?  @map("stripe_price_yearly_id")
  // UI copy.
  description          String?
  highlights           String[] @default([])
  sortOrder            Int      @default(100) @map("sort_order")

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId       String             @unique @map("organization_id") @db.Uuid
  planId               String             @map("plan_id") @db.Uuid
  status               SubscriptionStatus @default(trialing)
  // Stripe identifiers — only set once a real payment method is attached.
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  trialEndsAt          DateTime?          @map("trial_ends_at")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

// Append-only event log.
model UsageEvent {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  // 'message_outbound', 'message_inbound', 'product_write', 'service_write',
  // 'import_started', 'api_call', etc.
  kind           String
  count          Int      @default(1)
  occurredAt     DateTime @default(now()) @map("occurred_at")

  @@index([organizationId, kind, occurredAt(sort: Desc)])
  @@map("usage_events")
}

// Per-org-per-month roll-up populated by a daily worker job.
model UsageMonthly {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  // YYYY-MM key, lex-sortable.
  yearMonth      String   @map("year_month")
  kind           String
  count          Int      @default(0)
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, yearMonth, kind])
  @@index([organizationId, yearMonth])
  @@map("usage_monthly")
}

// ============================================================================
// PHASE 3 §5.1.4 — Branding (white-label) + Meta onboarding progress.
// ============================================================================

model BrandingConfig {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String    @unique @map("organization_id") @db.Uuid
  // Logo asset id (uploaded via existing Asset table).
  logoAssetId      String?   @map("logo_asset_id") @db.Uuid
  // Hex string, e.g. "#0070C9".
  accentColor      String?   @map("accent_color")
  // Custom domain like inbox.theircompany.com — DNS is the client's job.
  customCname      String?   @map("custom_cname")
  // CNAME validation state — set by the validate-cname endpoint:
  // null | 'pending' | 'verified' | 'failed'. Caddy's on-demand TLS asks
  // our /caddy/ask endpoint which only allows certs for 'verified' rows.
  cnameStatus      String?   @map("cname_status")
  cnameVerifiedAt  DateTime? @map("cname_verified_at")
  cnameLastCheckAt DateTime? @map("cname_last_check_at")
  cnameError       String?   @map("cname_error")
  // Free-form footer or signature.
  footerText       String?   @map("footer_text")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("branding_configs")
}

// Phase 3 §5.1.4 — GDPR data portability. One row per export request.
// The worker assembles a zip of the org's data, uploads it to Wasabi, and
// emails a signed URL to the requester. We retain rows for audit; the
// underlying storage object is the operator's call (TTL'd by the bucket).
model DataExport {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String    @map("organization_id") @db.Uuid
  // The user who clicked Export. Notified by email when the file is ready.
  requestedByUserId String    @map("requested_by_user_id") @db.Uuid
  status            String    @default("pending") // pending | running | succeeded | failed
  // Storage key inside Wasabi (e.g. "exports/<orgId>/<exportId>.zip"); set
  // when the worker finishes uploading. Signed URLs are minted on demand.
  storageKey        String?   @map("storage_key")
  fileSizeBytes     Int?      @map("file_size_bytes")
  errorMessage      String?   @map("error_message")
  startedAt         DateTime? @map("started_at")
  finishedAt        DateTime? @map("finished_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt(sort: Desc)])
  @@map("data_exports")
}

// One row per (org, step). Tracks the client's progress through Meta's
// 7-step business-verification + WhatsApp-onboarding workflow.
model MetaOnboardingStep {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  stepKey        String    @map("step_key")
  completedAt    DateTime? @map("completed_at")
  notes          String?

  @@unique([organizationId, stepKey])
  @@index([organizationId])
  @@map("meta_onboarding_steps")
}

// ============================================================================
// PHASE 4 — Broadcasts
// ----------------------------------------------------------------------------
// Persistent contacts + segments + bulk template campaigns sent through Meta.
// Per-recipient delivery state is updated by the existing message_status
// webhook (lookup by meta_message_id). The fanout worker materializes
// BroadcastRecipient rows; the send worker calls Meta one row at a time
// through the existing token-bucket rate limiter.
// ============================================================================

enum ContactSource {
  manual
  csv
  inbox_auto
  import
}

enum BroadcastStatus {
  draft
  scheduled
  sending
  paused
  completed
  cancelled
  failed
}

enum BroadcastAudienceKind {
  csv
  segment
  manual
  tags
}

enum BroadcastVariant {
  A
  B
}

enum RecipientStatus {
  pending
  queued
  sent
  delivered
  read
  failed
  skipped
}

enum BroadcastEventKind {
  created
  scheduled
  started
  paused
  resumed
  cancelled
  completed
  failed
  recipient_failed_burst
}

// One contact per phone number per org. Tag membership lives in ContactTag.
// `attributes` is free-form JSON that CSV imports + manual edits can populate
// (e.g. { "first_name": "Jane", "city": "Austin", "loyalty_tier": "gold" }).
// Variable mapping in broadcasts can pull from `attributes` keys directly.
model Contact {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  phoneE164      String        @map("phone_e164")
  // Operator-set nickname / business name. Free-form. Survives Meta
  // updates so a customer's preferred internal name isn't overwritten.
  displayName    String?       @map("display_name")
  // WhatsApp profile name (from Meta's inbound contacts[].profile.name).
  // Refreshed on every inbound message; read-only in the UI.
  whatsappName   String?       @map("whatsapp_name")
  locale         String? // BCP 47 tag (e.g. en, en_US)
  // Phase 5.3 — opt-in/out + IANA timezone for send-window enforcement.
  // optedInAt is informational; optedOutAt blocks future sends.
  optedInAt      DateTime?     @map("opted_in_at")
  optedOutAt     DateTime?     @map("opted_out_at")
  timezone       String? // IANA timezone (e.g. "America/Los_Angeles")
  attributes     Json          @default("{}")
  source         ContactSource @default(manual)
  lastInboundAt  DateTime?     @map("last_inbound_at")
  lastOutboundAt DateTime?     @map("last_outbound_at")
  // Soft-delete flag — suppressed contacts skip send but rows persist for audit.
  deletedAt      DateTime?     @map("deleted_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tags         ContactTag[]
  recipients   BroadcastRecipient[]
  enrollments  SequenceEnrollment[]

  @@unique([organizationId, phoneE164])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([organizationId, deletedAt])
  @@map("contacts")
}

model ContactTag {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  contactId      String   @map("contact_id") @db.Uuid
  tag            String
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, tag])
  @@index([organizationId, tag])
  @@map("contact_tags")
}

// `filter` is a normalized AST: { mode: 'all'|'any', clauses: [...] }.
// Schema enforced in Zod (packages/shared/src/schemas/broadcast.ts) and
// evaluated by apps/api/src/modules/contacts/segment-evaluator.ts.
model Segment {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  description    String?
  filter         Json
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  broadcasts   Broadcast[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("segments")
}

// One campaign. Recipients live in BroadcastRecipient. A/B test toggles
// variant_b_template_id + variant_b_variables; without A/B the broadcast is
// 100% variant A. Variables maps are { templateParamIndex: source } where
// source = { kind: 'csv'|'attribute'|'static', value: string }.
model Broadcast {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId      String                @map("organization_id") @db.Uuid
  name                String
  status              BroadcastStatus       @default(draft)
  channelId           String                @map("channel_id") @db.Uuid
  audienceKind        BroadcastAudienceKind @map("audience_kind")
  csvAssetId          String?               @map("csv_asset_id") @db.Uuid
  segmentId           String?               @map("segment_id") @db.Uuid
  // Tag-based audience. Populated when audienceKind = 'tags'. The fanout
  // worker resolves these to Contact rows at send time by intersecting
  // ContactTag.tag against this list (mode picks OR vs AND).
  audienceTags        String[]              @default([]) @map("audience_tags")
  audienceTagsMode    String                @default("any") @map("audience_tags_mode") // 'any' (OR) | 'all' (AND)
  // A/B test
  abTest              Boolean               @default(false) @map("ab_test")
  variantATemplateId  String                @map("variant_a_template_id") @db.Uuid
  variantBTemplateId  String?               @map("variant_b_template_id") @db.Uuid
  variantAVariables   Json                  @default("{}") @map("variant_a_variables")
  variantBVariables   Json?                 @map("variant_b_variables")
  // Scheduling
  scheduledFor        DateTime?             @map("scheduled_for")
  startedAt           DateTime?             @map("started_at")
  completedAt         DateTime?             @map("completed_at")
  // Phase 5.3 — send window in the channel's timezone (or per-contact if set).
  // Hours stored as 0-23. Send worker requeues recipients outside the window.
  sendWindowStartHour Int?                  @map("send_window_start_hour")
  sendWindowEndHour   Int?                  @map("send_window_end_hour")
  sendWindowTimezone  String?               @map("send_window_timezone")
  // Phase 5.3 — post-hoc A/B winner determination. Set when broadcast completes.
  // Strategy: 'read_rate' | 'response_rate' | 'manual' | null (no determination).
  abWinnerStrategy    String?               @map("ab_winner_strategy")
  abWinnerVariant     BroadcastVariant?     @map("ab_winner_variant")
  abWinnerDecidedAt   DateTime?             @map("ab_winner_decided_at")
  // Counters — kept consistent by the fanout/send workers + webhook handler.
  totalRecipients     Int                   @default(0) @map("total_recipients")
  queuedCount         Int                   @default(0) @map("queued_count")
  sentCount           Int                   @default(0) @map("sent_count")
  deliveredCount      Int                   @default(0) @map("delivered_count")
  readCount           Int                   @default(0) @map("read_count")
  failedCount         Int                   @default(0) @map("failed_count")
  // The user who clicked Send. May be NULL if the user is later deleted.
  createdByUserId     String?               @map("created_by_user_id") @db.Uuid
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  segment      Segment?             @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  recipients   BroadcastRecipient[]
  events       BroadcastEvent[]

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([organizationId, status])
  @@map("broadcasts")
}

model BroadcastRecipient {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String           @map("organization_id") @db.Uuid
  broadcastId      String           @map("broadcast_id") @db.Uuid
  contactId        String?          @map("contact_id") @db.Uuid
  phoneE164        String           @map("phone_e164")
  variant          BroadcastVariant @default(A)
  // Resolved per-recipient template parameters: { "1": "Jane", "2": "Gold" }.
  variables        Json             @default("{}")
  status           RecipientStatus  @default(pending)
  // Meta wamid set when send succeeds. message_status webhook joins on this.
  metaMessageId    String?          @map("meta_message_id")
  metaErrorCode    String?          @map("meta_error_code")
  metaErrorMessage String?          @map("meta_error_message")
  queuedAt         DateTime?        @map("queued_at")
  sentAt           DateTime?        @map("sent_at")
  deliveredAt      DateTime?        @map("delivered_at")
  readAt           DateTime?        @map("read_at")
  failedAt         DateTime?        @map("failed_at")
  attemptCount     Int              @default(0) @map("attempt_count")
  createdAt        DateTime         @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  broadcast    Broadcast    @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([broadcastId, status])
  @@index([organizationId, metaMessageId])
  @@index([broadcastId, createdAt(sort: Asc)])
  @@map("broadcast_recipients")
}

// Coarse-grained timeline of campaign events for the detail page.
model BroadcastEvent {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  broadcastId    String             @map("broadcast_id") @db.Uuid
  kind           BroadcastEventKind
  detail         Json?
  createdAt      DateTime           @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  broadcast    Broadcast    @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@index([broadcastId, createdAt(sort: Asc)])
  @@map("broadcast_events")
}

// ============================================================================
// PHASE 5.4 — Drip / sequence campaigns
// ============================================================================

enum SequenceEnrollmentStatus {
  active
  paused
  completed
  cancelled
}

model Sequence {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  name            String
  description     String?
  isActive        Boolean  @default(true) @map("is_active")
  channelId       String   @map("channel_id") @db.Uuid
  createdByUserId String?  @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  steps        SequenceStep[]
  enrollments  SequenceEnrollment[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("sequences")
}

model SequenceStep {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  sequenceId     String   @map("sequence_id") @db.Uuid
  stepOrder      Int      @map("step_order")
  templateId     String   @map("template_id") @db.Uuid
  delayHours     Int      @default(0) @map("delay_hours")
  variables      Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sequence     Sequence     @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, stepOrder])
  @@index([sequenceId])
  @@map("sequence_steps")
}

model SequenceEnrollment {
  id             String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String                   @map("organization_id") @db.Uuid
  sequenceId     String                   @map("sequence_id") @db.Uuid
  contactId      String                   @map("contact_id") @db.Uuid
  status         SequenceEnrollmentStatus @default(active)
  nextStepIndex  Int                      @default(0) @map("next_step_index")
  nextStepDueAt  DateTime?                @map("next_step_due_at")
  enrolledAt     DateTime                 @default(now()) @map("enrolled_at")
  completedAt    DateTime?                @map("completed_at")
  cancelledAt    DateTime?                @map("cancelled_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sequence     Sequence     @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, contactId])
  @@index([organizationId, status, nextStepDueAt])
  @@map("sequence_enrollments")
}

// ----------------------------------------------------------------------------
// Phase 8 — AI message provenance / audit trail.
//
// Every outbound bot reply gets one MessageProvenance row capturing exactly
// what we fed the LLM (system prompt hash + candidate catalog/business-info
// rows + history) and what the LLM cited / fabricated in its reply. Lets
// ALIGNED admins audit "where did the bot get this answer from?" for any
// message in the inbox.
//
// The system prompt is content-addressed via SystemPromptSnapshot so we
// don't store the same 3-5KB prompt with every message — it only changes
// when the operator edits BotConfig.
// ----------------------------------------------------------------------------

model SystemPromptSnapshot {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  // SHA-256 of the body, hex-encoded. Dedupes identical prompts within an
  // org (the prompt only changes when BotConfig is edited).
  sha256         String   @db.Char(64)
  body           String
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provenances  MessageProvenance[]

  @@unique([organizationId, sha256])
  @@index([organizationId, createdAt(sort: Desc)])
  @@map("system_prompt_snapshots")
}

model MessageProvenance {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  // The bot's outbound WhatsApp message this provenance describes.
  // 1:1 — every bot message gets exactly one provenance row.
  messageId      String @unique @map("message_id") @db.Uuid

  // FK to the deduped system prompt body.
  systemPromptSnapshotId String @map("system_prompt_snapshot_id") @db.Uuid

  // What the LLM saw on this turn.
  userPrompt  String @map("user_prompt")
  historyJson Json   @map("history_json")

  // The candidate set we packed into the prompt (subset of catalog/biz-info).
  // The Phase 1.2 scanner cross-references these against the reply text to
  // produce `citations` (what the LLM actually used). Anything the LLM
  // mentioned that ISN'T in these arrays is a potential hallucination.
  candidateProductIds  String[] @map("candidate_product_ids") @db.Uuid
  candidateServiceIds  String[] @map("candidate_service_ids") @db.Uuid
  candidateFaqIds      String[] @map("candidate_faq_ids") @db.Uuid
  candidatePolicyKinds String[] @map("candidate_policy_kinds")
  businessInfoFields   String[] @map("business_info_fields")

  // Filled by the Phase 1.2 post-LLM scanner. Nullable here so Phase 1.1
  // can ship before the scanner exists.
  citations      Json?
  hallucinations Json?
  // Phase 13 — per-station pipeline timing trace. Shape:
  //   { totalMs, laps: [{ station, durationMs, cumulativeMs }] }
  // Filled by the Stopwatch threaded through maybeReplyAsBot.
  pipelineTimings Json? @map("pipeline_timings")

  // LLM call metadata.
  model            String
  temperature      Float
  promptTokens     Int    @map("prompt_tokens")
  completionTokens Int    @map("completion_tokens")
  latencyMs        Int    @map("latency_ms")

  createdAt DateTime @default(now()) @map("created_at")

  organization         Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  message              WhatsAppMessage      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  systemPromptSnapshot SystemPromptSnapshot @relation(fields: [systemPromptSnapshotId], references: [id], onDelete: Restrict)
  flagDecisions        ProvenanceFlagDecision[]

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([systemPromptSnapshotId])
  @@map("message_provenances")
}

// ----------------------------------------------------------------------------
// Phase 8 / 1.7 — operator feedback loop.
//
// ProvenanceSuppression — phrases the scanner should NOT flag. Org-scoped
// for tenant-specific noise (e.g. their own brand name overlapping with
// an English word) and org_id-nullable for GLOBAL entries that apply to
// every tenant (e.g. order-summary labels like "Subtotal", currency
// codes, etc.). ALIGNED admins can promote per-org rows to global.
//
// ProvenanceFlagDecision — every click on the ✓ Not a problem / ⚠ Yes
// wrong / 🤷 Skip buttons writes a row here. Drives precision metrics
// and the auto-suggest "≥3 tenants suppressed this — promote globally?"
// banner.
// ----------------------------------------------------------------------------

model ProvenanceSuppression {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // NULL = global (applies to all tenants). Non-NULL = per-org.
  organizationId String?  @map("organization_id") @db.Uuid
  // Lower-cased + whitespace-normalised phrase. Scanner normalises
  // matchedText the same way at scan time, then SELECTs.
  phrase         String
  note           String?
  createdByUserId String? @map("created_by_user_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  // Bumped each time the scanner suppresses a flag because of this row.
  matchesCount   Int      @default(0) @map("matches_count")
  lastMatchedAt  DateTime? @map("last_matched_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?         @relation("ProvenanceSuppressionAuthor", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt(sort: Desc)])
  @@map("provenance_suppressions")
}

model ProvenanceFlagDecision {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  provenanceId    String   @map("provenance_id") @db.Uuid
  // Index into MessageProvenance.hallucinations JSONB array.
  flagIndex       Int      @map("flag_index")
  flaggedText     String   @map("flagged_text")
  // 'false_positive' | 'true_positive' | 'skip'
  decision        String
  decidedByUserId String?  @map("decided_by_user_id") @db.Uuid
  decidedAt       DateTime @default(now()) @map("decided_at")
  note            String?

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provenance   MessageProvenance @relation(fields: [provenanceId], references: [id], onDelete: Cascade)
  decidedBy    User?             @relation("ProvenanceFlagDecider", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@unique([provenanceId, flagIndex])
  @@index([organizationId, decidedAt(sort: Desc)])
  @@map("provenance_flag_decisions")
}

// ----------------------------------------------------------------------------
// Lead (GLOBAL) — public marketing-site capture (name + WhatsApp number).
// Not tenant-scoped: these are ALIGNED's own inbound leads, viewed only in
// /aligned-admin/leads. No organization_id → no RLS policy; accessed via
// withRlsBypass() from the public capture route + admin routes.
// ----------------------------------------------------------------------------

enum LeadStatus {
  new
  contacted
  converted
  archived
}

model Lead {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  phone     String
  source    String     @default("hader_landing")
  status    LeadStatus @default(new)
  note      String?
  createdAt DateTime   @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@map("leads")
}
